/* pages/index/index.wxss - 首页样式 */

/* 设备状态栏 */
.status-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, rgba(223, 67, 45, 0.96), rgba(252, 134, 75, 0.88));
  border-radius: 30rpx;
  box-shadow: 0 20rpx 46rpx rgba(211, 75, 40, 0.24);
  color: #ffffff;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.status-dot.online {
  background: #ffdd77;
  box-shadow: 0 0 18rpx rgba(255, 221, 119, 0.8);
}

.status-dot.offline {
  background: #ff7a59;
  box-shadow: 0 0 18rpx rgba(255, 122, 89, 0.75);
}

.status-text {
  font-size: 28rpx;
  font-weight: 700;
  flex: 1;
}

.update-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.78);
}

/* 数值显示 */
.card-value {
  display: flex;
  align-items: baseline;
  padding-left: 48rpx;
  position: relative;
  z-index: 1;
}

.value-num {
  font-size: 64rpx;
  font-weight: 800;
  color: #e94f37;
  text-shadow: 0 8rpx 20rpx rgba(233, 79, 55, 0.13);
}

.value-unit {
  font-size: 28rpx;
  color: #a08378;
  margin-left: 8rpx;
}

.value-hint {
  padding-left: 48rpx;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #f46d43;
  font-weight: 600;
}

/* 窗帘状态 */
.curtain-info {
  display: flex;
  align-items: center;
  padding-left: 48rpx;
  position: relative;
  z-index: 1;
}

.curtain-bar-bg {
  flex: 1;
  height: 18rpx;
  background: rgba(233, 79, 55, 0.12);
  border-radius: 999rpx;
  overflow: hidden;
}

.curtain-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffb84d 0%, #ff7043 52%, #e94f37 100%);
  border-radius: 999rpx;
  transition: width 0.5s ease;
  box-shadow: 0 0 18rpx rgba(255, 112, 67, 0.36);
}

.curtain-percent {
  width: 100rpx;
  text-align: right;
  font-size: 30rpx;
  font-weight: 800;
  color: #e94f37;
}

.curtain-mode {
  font-size: 24rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: #fff3d6;
  color: #c46c08;
  border: 1rpx solid rgba(196, 108, 8, 0.22);
  font-weight: 700;
}

.curtain-desc {
  padding-left: 48rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #a08378;
}

/* 模式切换 */
.mode-desc {
  font-size: 24rpx;
  color: #a08378;
  margin-bottom: 20rpx;
  padding-left: 48rpx;
}

.mode-row {
  display: flex;
  gap: 20rpx;
}

.mode-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #8b6458;
  background: rgba(255, 255, 255, 0.72);
  border: 2rpx solid rgba(233, 79, 55, 0.13);
  transition: all 0.3s;
}

.mode-btn.active {
  background: linear-gradient(135deg, #e94f37 0%, #ff8a4c 100%);
  color: #ffffff;
  border-color: rgba(255, 255, 255, 0.7);
  font-weight: 700;
  box-shadow: 0 14rpx 28rpx rgba(233, 79, 55, 0.22);
}

.mode-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

/* 底部 */
.footer-tip {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.footer-tip text {
  font-size: 22rpx;
  color: #a08378;
}

