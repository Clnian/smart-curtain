/* app.wxss - 全局样式 */
page {
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background:
    radial-gradient(circle at 12% 8%, rgba(255, 203, 112, 0.34) 0, rgba(255, 203, 112, 0) 260rpx),
    radial-gradient(circle at 92% 16%, rgba(255, 112, 84, 0.28) 0, rgba(255, 112, 84, 0) 300rpx),
    linear-gradient(180deg, #fff8ea 0%, #fff0e8 44%, #fff7f1 100%);
  color: #392824;
  font-size: 28rpx;
  box-sizing: border-box;
  min-height: 100%;
}

.container {
  padding: 28rpx 24rpx 36rpx;
}

/* 通用卡片 */
.card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.86);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  box-shadow: 0 18rpx 46rpx rgba(133, 69, 42, 0.14);
}

.card::before {
  content: "";
  position: absolute;
  top: -70rpx;
  right: -70rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(255, 178, 91, 0.16);
  pointer-events: none;
}

.card-header {
  position: relative;
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
  z-index: 1;
}

.card-icon {
  width: 54rpx;
  height: 54rpx;
  line-height: 54rpx;
  text-align: center;
  font-size: 34rpx;
  margin-right: 14rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #fff2bd 0%, #ffd7c8 100%);
  box-shadow: inset 0 -4rpx 10rpx rgba(255, 255, 255, 0.55);
}

.card-title {
  font-size: 29rpx;
  color: #46302a;
  flex: 1;
  font-weight: 700;
  letter-spacing: 1rpx;
}

/* 告警标签 */
.alarm-tag {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: #fff0d9;
  color: #c56a00;
  border: 1rpx solid rgba(197, 106, 0, 0.22);
  font-weight: 600;
}

.alarm-tag.alarm {
  background: #fff1e8;
  color: #e5533d;
  border-color: rgba(229, 83, 61, 0.28);
}

/* 操作反馈 */
.toast {
  text-align: center;
  padding: 20rpx;
  font-size: 24rpx;
  color: #a08378;
}

